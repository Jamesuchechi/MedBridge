# ─── App ────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=MedBridge
NEXT_PUBLIC_ENVIRONMENT=development

# ─── API ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
AI_SERVICE_URL=http://localhost:8000

# ─── Database ────────────────────────────────────────────────────────────────
# Use Supabase or Local Postgres
DATABASE_URL=postgresql://user:password@localhost:5432/medbridge
REDIS_URL=redis://localhost:6379

# ─── Auth ─────────────────────────────────────────────────────────────────────
NEXTAUTH_SECRET=generate-a-32-char-random-string
NEXTAUTH_URL=http://localhost:3000
JWT_SERVICE_SECRET=your-service-jwt-secret

# ─── AI Services ─────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GROQ_API_KEY=
OPENAI_API_KEY=

# ─── File Storage (Cloudflare R2) ─────────────────────────────────────────────
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=medbridge-documents

# ─── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ─── Email ────────────────────────────────────────────────────────────────────
RESEND_API_KEY=

# ─── SMS / USSD (Africa's Talking) ────────────────────────────────────────────
AT_API_KEY=
AT_USERNAME=sandbox
AT_SENDER_ID=MedBridge

# ─── Payments (Paystack) ──────────────────────────────────────────────────────
PAYSTACK_SECRET_KEY=
NEXT_PUBLIC_PAYSTACK_PUBLIC_KEY=

# ─── Maps ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# ─── Observability ────────────────────────────────────────────────────────────
NEXT_PUBLIC_POSTHOG_KEY=
SENTRY_DSN=

# ─── Misc ─────────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=debug
USE_MOCK_LLM=false
